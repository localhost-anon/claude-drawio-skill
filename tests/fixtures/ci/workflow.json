{
  "name": "CI",
  "on": {
    "push": null,
    "pull_request": null
  },
  "jobs": {
    "lint": {
      "runs-on": "ubuntu-latest",
      "steps": []
    },
    "test": {
      "needs": "lint",
      "runs-on": "ubuntu-latest",
      "strategy": {
        "matrix": {
          "node": [18, 20, 22],
          "os": ["ubuntu-latest", "macos-latest"]
        }
      },
      "steps": []
    },
    "deploy": {
      "needs": ["lint", "test"],
      "uses": "octo-org/octo-repo/.github/workflows/deploy.yml@main"
    },
    "notify": {
      "runs-on": "ubuntu-latest"
    }
  }
}
